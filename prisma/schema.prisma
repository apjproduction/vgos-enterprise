model Organization {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  website              String?               @db.Text
  description          String                @db.Text
  workspaces           Workspace[]
  personas             Persona[]
  conversations        Conversation[]
  questions            Question[]
  painPoints           PainPoint[]
  contentAssets        ContentAsset[]
  keywords             Keyword[]
  entities             Entity[]
  communities          Community[]
  competitors          Competitor[]
  directorySubmissions DirectorySubmission[]
  backlinks            Backlink[]
  campaigns            Campaign[]
  tasks                Task[]
  featureRequests      FeatureRequest[]
  observations         Observation[]
  insights             Insight[]
  hypotheses           Hypothesis[]
  experiments          Experiment[]
  outcomes             Outcome[]
  knowledgeNodes       KnowledgeNode[]
  knowledgeEdges       KnowledgeEdge[]
  aiRecommendations    AIRecommendation[]
  intelligenceObjects  IntelligenceObject[]
  memories             Memory[]
  patterns             Pattern[]
  reasoningTraces      ReasoningTrace[]
  objectives           Objective[]
  agents               Agent[]
  agentRuns            AgentRun[]
  knowledgeObjects     KnowledgeObject[]
  knowledgeRelationships KnowledgeRelationship[]
  memorySnapshots      MemorySnapshot[]
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  agentHandoffs        AgentHandoff[]
  plans                Plan[]
  milestones           Milestone[]
  planItems            PlanItem[]
  planDependencies     PlanDependency[]
  planConstraints      PlanConstraint[]
  predictedOutcomes    PredictedOutcome[]
  resourceCapacities   ResourceCapacity[]
  executionItems       ExecutionItem[]
  executionEvidence    ExecutionEvidence[]
  executionBlockers    ExecutionBlocker[]
  approvalRequests     ApprovalRequest[]
  executionResults     ExecutionResult[]
  metrics              Metric[]
  measurements         Measurement[]
  learnings            Learning[]
  attributions         Attribution[]
  strategyAdjustments  StrategyAdjustment[]
  missions             Mission[]
  connectors           Connector[]
  rawSignals           RawSignal[]
  normalizedSignals    NormalizedSignal[]
  connectorSyncRuns    ConnectorSyncRun[]
  events               Event[]
  recommendedActions   RecommendedAction[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String
  organizationId       String
  companyProductName   String?
  website              String?
  timezone             String?               @default("America/Los_Angeles")
  defaultOwner         String?
  productDescription   String?               @db.Text
  targetAudience       String?               @db.Text
  positioning          String?               @db.Text
  competitorNames      String[]              @default([])
  weeklyCapacity       Int?                  @default(20)
  defaultMissionPriority Priority?           @default(HIGH)
  contentCadence       String?
  approvalRequirements String[]              @default([])
  onboardingCompleted  Boolean               @default(false)
  onboardingCompletedAt DateTime?
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personas             Persona[]
  conversations        Conversation[]
  questions            Question[]
  painPoints           PainPoint[]
  contentAssets        ContentAsset[]
  keywords             Keyword[]
  entities             Entity[]
  communities          Community[]
  competitors          Competitor[]
  directorySubmissions DirectorySubmission[]
  backlinks            Backlink[]
  campaigns            Campaign[]
  tasks                Task[]
  featureRequests      FeatureRequest[]
  observations         Observation[]
  insights             Insight[]
  hypotheses           Hypothesis[]
  experiments          Experiment[]
  outcomes             Outcome[]
  knowledgeNodes       KnowledgeNode[]
  knowledgeEdges       KnowledgeEdge[]
  aiRecommendations    AIRecommendation[]
  intelligenceObjects  IntelligenceObject[]
  memories             Memory[]
  patterns             Pattern[]
  reasoningTraces      ReasoningTrace[]
  objectives           Objective[]
  agents               Agent[]
  agentRuns            AgentRun[]
  knowledgeObjects     KnowledgeObject[]
  knowledgeRelationships KnowledgeRelationship[]
  memorySnapshots      MemorySnapshot[]
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  agentHandoffs        AgentHandoff[]
  plans                Plan[]
  milestones           Milestone[]
  planItems            PlanItem[]
  planDependencies     PlanDependency[]
  planConstraints      PlanConstraint[]
  predictedOutcomes    PredictedOutcome[]
  resourceCapacities   ResourceCapacity[]
  executionItems       ExecutionItem[]
  executionEvidence    ExecutionEvidence[]
  executionBlockers    ExecutionBlocker[]
  approvalRequests     ApprovalRequest[]
  executionResults     ExecutionResult[]
  metrics              Metric[]
  measurements         Measurement[]
  learnings            Learning[]
  attributions         Attribution[]
  strategyAdjustments  StrategyAdjustment[]
  missions             Mission[]
  missionObjectives    MissionObjective[]
  missionPlans         MissionPlan[]
  missionExecutions    MissionExecution[]
  missionLearnings     MissionLearning[]
  missionMetrics       MissionMetric[]
  missionSummaries     MissionSummary[]
  connectors           Connector[]
  rawSignals           RawSignal[]
  normalizedSignals    NormalizedSignal[]
  connectorSyncRuns    ConnectorSyncRun[]
  events               Event[]
  recommendedActions   RecommendedAction[]
  auditLogs            AuditLog[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Persona {
  id                String           @id @default(cuid())
  name              String
  description       String           @db.Text
  industry          String
  buyingIntent      String
  primaryPainPoint  String           @db.Text
  contentNeeds      String           @db.Text
  organizationId    String
  workspaceId       String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  questions         Question[]
  painPoints        PainPoint[]
  contentAssets     ContentAsset[]
  featureRequests   FeatureRequest[]
  campaigns         Campaign[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@index([workspaceId])
}

model Conversation {
  id                String             @id @default(cuid())
  title             String
  description       String             @db.Text
  source            String
  url               String?            @db.Text
  status            Status             @default(NOT_STARTED)
  priority          Priority           @default(MEDIUM)
  owner             String
  organizationId    String
  workspaceId       String
  communityId       String?
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  community         Community?         @relation(fields: [communityId], references: [id], onDelete: SetNull)
  questions         Question[]
  painPoints        PainPoint[]
  aiRecommendations AIRecommendation[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([communityId])
  @@index([priority])
  @@index([status])
  @@index([owner])
}

model Question {
  id                   String                 @id @default(cuid())
  title                String
  description          String                 @db.Text
  source               String
  url                  String?                @db.Text
  status               Status                 @default(RESEARCHING)
  priority             Priority               @default(MEDIUM)
  owner                String
  intent               Intent?
  funnelStage          FunnelStage?
  searchVolumeEstimate Int?
  businessValueScore   Int                    @default(0)
  painSeverityScore    Int                    @default(0)
  competitionScore     Int                    @default(0)
  trendScore           Int                    @default(0)
  authorityGapScore    Int                    @default(0)
  opportunityScore     Int                    @default(0)
  organizationId       String
  workspaceId          String
  conversationId       String?
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace            Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation         Conversation?          @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  personas             Persona[]
  contentAssets        QuestionContentAsset[]
  aiRecommendations    AIRecommendation[]
  recommendedActions   RecommendedAction[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([conversationId])
  @@index([intent])
  @@index([funnelStage])
  @@index([priority])
  @@index([status])
  @@index([opportunityScore])
}

model PainPoint {
  id                   String             @id @default(cuid())
  title                String
  description          String             @db.Text
  source               String
  url                  String?            @db.Text
  status               Status             @default(RESEARCHING)
  priority             Priority           @default(MEDIUM)
  owner                String
  searchVolumeEstimate Int?
  businessValueScore   Int                @default(0)
  painSeverityScore    Int                @default(0)
  competitionScore     Int                @default(0)
  trendScore           Int                @default(0)
  authorityGapScore    Int                @default(0)
  opportunityScore     Int                @default(0)
  organizationId       String
  workspaceId          String
  conversationId       String?
  competitorId         String?
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation         Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  competitor           Competitor?        @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  personas             Persona[]
  featureRequests      FeatureRequest[]
  aiRecommendations    AIRecommendation[]
  recommendedActions   RecommendedAction[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([conversationId])
  @@index([competitorId])
  @@index([priority])
  @@index([status])
  @@index([opportunityScore])
}

model ContentAsset {
  id                String                 @id @default(cuid())
  code              String?
  title             String
  description       String                 @db.Text
  source            String
  url               String?                @db.Text
  status            Status                 @default(NOT_STARTED)
  priority          Priority               @default(MEDIUM)
  owner             String
  contentType       ContentType
  intent            Intent?
  funnelStage       FunnelStage?
  organizationId    String
  workspaceId       String
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  personas          Persona[]
  questions         QuestionContentAsset[]
  keywords          ContentAssetKeyword[]
  entities          ContentAssetEntity[]
  campaigns         CampaignContentAsset[]
  aiRecommendations AIRecommendation[]
  recommendedActions RecommendedAction[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([workspaceId, code])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([contentType])
  @@index([funnelStage])
  @@index([intent])
  @@index([priority])
  @@index([status])
}

model Keyword {
  id             String                @id @default(cuid())
  name           String
  description    String                @db.Text
  source         String
  url            String?               @db.Text
  status         Status                @default(RESEARCHING)
  priority       Priority              @default(MEDIUM)
  owner          String
  intent         Intent?
  funnelStage    FunnelStage?
  organizationId String
  workspaceId    String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentAssets  ContentAssetKeyword[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([intent])
  @@index([funnelStage])
  @@index([priority])
  @@index([status])
}

model Entity {
  id              String               @id @default(cuid())
  name            String
  description     String               @db.Text
  source          String
  url             String?              @db.Text
