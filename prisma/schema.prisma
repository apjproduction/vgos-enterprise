}

model Connector {
  id                String              @id @default(cuid())
  organizationId    String
  workspaceId       String
  name              String
  connectorType     ConnectorType
  status            ConnectorStatus     @default(DRAFT)
  provider          String
  description       String              @db.Text
  authType          AuthType            @default(NONE)
  config            Json
  lastSyncAt        DateTime?
  nextSyncAt        DateTime?
  healthScore       Float               @default(0)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rawSignals        RawSignal[]
  normalizedSignals NormalizedSignal[]
  syncRuns          ConnectorSyncRun[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([connectorType])
  @@index([status])
  @@index([provider])
  @@index([lastSyncAt])
  @@index([healthScore])
}

model RawSignal {
  id                String             @id @default(cuid())
  organizationId    String
  workspaceId       String
  connectorId       String
  source            String
  sourceType        String
  externalId        String?
  rawPayload        Json
  receivedAt        DateTime
  processedAt       DateTime?
  status            RawSignalStatus    @default(RECEIVED)
  error             String?            @db.Text
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector         Connector          @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  normalizedSignals NormalizedSignal[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([connectorId])
  @@index([sourceType])
  @@index([externalId])
  @@index([status])
  @@index([receivedAt])
}

model NormalizedSignal {
  id              String        @id @default(cuid())
  organizationId  String
  workspaceId     String
  rawSignalId     String
  connectorId     String
  signalType      SignalType
  title           String
  summary         String        @db.Text
  sourceUrl       String?       @db.Text
  author          String?
  platform        String?
  occurredAt      DateTime
  confidenceScore Float         @default(0)
  priority        Priority      @default(MEDIUM)
  metadata        Json
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rawSignal       RawSignal     @relation(fields: [rawSignalId], references: [id], onDelete: Cascade)
  connector       Connector     @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([rawSignalId])
  @@index([connectorId])
  @@index([signalType])
  @@index([priority])
  @@index([occurredAt])
}

model ConnectorSyncRun {
  id                String       @id @default(cuid())
  organizationId    String
  workspaceId       String
  connectorId       String
  status            SyncStatus
  startedAt         DateTime
  completedAt       DateTime?
  recordsFetched    Int          @default(0)
  recordsNormalized Int          @default(0)
  recordsRouted     Int          @default(0)
  error             String?      @db.Text
  logs              Json
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector         Connector    @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([connectorId])
  @@index([status])
  @@index([startedAt])
}

model Event {
  id             String        @id @default(cuid())
  workspaceId    String
  eventType      EventType
  sourceType     String
  sourceId       String
  title          String
  description    String        @db.Text
  metadata       Json
  severity       EventSeverity @default(MEDIUM)
  status         EventStatus   @default(PENDING)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  processedAt    DateTime?

  @@index([organizationId])
  @@index([workspaceId])
  @@index([eventType])
  @@index([sourceType, sourceId])
  @@index([severity])
  @@index([status])
}

model RecommendedAction {
  id                    String               @id @default(cuid())
  workspaceId           String
  title                 String
  description           String               @db.Text
  sourceType            String
  sourceId              String
  actionType            ActionType
  priority              Priority             @default(MEDIUM)
  status                ActionStatus         @default(PENDING)
  dueDate               DateTime?
  owner                 String
  reasoning             String               @db.Text
  expectedImpact        String               @db.Text
  confidenceScore       Float                @default(0)
  qualityScore          Float                @default(0)
  evidenceStrength      Float                @default(0)
  missingEvidence       Json                 @default("[]")
  duplicateRisk         Float                @default(0)
  confidenceExplanation String               @default("") @db.Text
  reviewedAt            DateTime?
  reviewedBy            String?
  completedAt           DateTime?
  organizationId        String
  questionId            String?
  painPointId           String?
  observationId         String?
  contentAssetId        String?
  aiRecommendationId    String?
  experimentId          String?
  directorySubmissionId String?
  backlinkId            String?
  competitorId          String?
  objectiveId           String?
  patternId             String?
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace             Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  question              Question?            @relation(fields: [questionId], references: [id], onDelete: SetNull)
  painPoint             PainPoint?           @relation(fields: [painPointId], references: [id], onDelete: SetNull)
  observation           Observation?         @relation(fields: [observationId], references: [id], onDelete: SetNull)
  contentAsset          ContentAsset?        @relation(fields: [contentAssetId], references: [id], onDelete: SetNull)
  aiRecommendation      AIRecommendation?    @relation(fields: [aiRecommendationId], references: [id], onDelete: SetNull)
  experiment            Experiment?          @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  directorySubmission   DirectorySubmission? @relation(fields: [directorySubmissionId], references: [id], onDelete: SetNull)
  backlink              Backlink?            @relation(fields: [backlinkId], references: [id], onDelete: SetNull)
  competitor            Competitor?          @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  objective             Objective?           @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  pattern               Pattern?             @relation(fields: [patternId], references: [id], onDelete: SetNull)
  executionItems        ExecutionItem[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([sourceType, sourceId])
  @@index([actionType])
  @@index([priority])
  @@index([status])
  @@index([dueDate])
  @@index([objectiveId])
  @@index([patternId])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actor       String
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  metadata    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([actor])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model QuestionContentAsset {
  questionId     String
  contentAssetId String
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([questionId, contentAssetId])
}

model ContentAssetKeyword {
  contentAssetId String
  keywordId      String
  primary        Boolean      @default(false)
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  keyword        Keyword      @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([contentAssetId, keywordId])
}

model ContentAssetEntity {
  contentAssetId String
  entityId       String
  primary        Boolean      @default(false)
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  entity         Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([contentAssetId, entityId])
}

model CampaignContentAsset {
  campaignId     String
  contentAssetId String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([campaignId, contentAssetId])
}
