  handoffsTo     AgentHandoff[] @relation("AgentHandoffTo")
  runs           AgentRun[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([workspaceId])
  @@index([agentType])
  @@index([status])
  @@index([parentAgentId])
}

